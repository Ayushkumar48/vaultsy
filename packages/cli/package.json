{
	"name": "vaultsy-cli",
	"version": "0.1.0",
	"description": "Official CLI for Vaultsy — pull, push, and inject secrets from your terminal",
	"type": "module",
	"bin": {
		"vaultsy": "./dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"start": "node dist/index.js"
	},
	"dependencies": {
		"@vaultsy/shared": "workspace:*",
		"chalk": "^5.4.1",
		"commander": "^14.0.0",
		"ora": "^8.2.0",
		"@clack/prompts": "^0.9.1"
	},
	"devDependencies": {
		"@types/node": "^24",
		"typescript": "^5.9.3"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"keywords": [
		"vaultsy",
		"secrets",
		"env",
		"cli",
		"dotenv"
	],
	"license": "MIT"
}
