{
	"name": "vaultsy-cli",
	"version": "0.1.3",
	"description": "Official CLI for Vaultsy — pull, push, and inject secrets from your terminal",
	"type": "module",
	"bin": {
		"vaultsy": "dist/index.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"start": "node dist/index.js",
		"prepublishOnly": "bun run build"
	},
	"dependencies": {
		"@clack/prompts": "^0.9.1",
		"chalk": "^5.4.1",
		"commander": "^14.0.0",
		"ora": "^8.2.0"
	},
	"devDependencies": {
		"@types/node": "^24",
		"@vaultsy/shared": "workspace:*",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"keywords": [
		"vaultsy",
		"secrets",
		"env",
		"cli",
		"dotenv",
		"environment-variables",
		"secret-management"
	],
	"homepage": "https://vaultsy.vercel.app",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Ayushkumar48/vaultsy.git",
		"directory": "packages/cli"
	},
	"bugs": {
		"url": "https://github.com/Ayushkumar48/vaultsy/issues"
	},
	"license": "MIT"
}
